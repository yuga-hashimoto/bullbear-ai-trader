# ============================================================================
# bullbear-ai-trader environment variables (EXAMPLE)
# Copy to `.env` and fill in. NEVER commit your real .env.
# ============================================================================

# --- LIVE TRADING SAFETY GATE -----------------------------------------------
# Live trading is DISABLED by default and requires ALL of the following:
#   1. config: live_trading_enabled: true
#   2. this env var set to exactly "1"
#   3. an explicit --i-understand-live-trading-risk CLI flag
# Leave this unset (or 0) for backtest/paper only.
BULLBEAR_ALLOW_LIVE=0

# --- moomoo / Futu OpenD (future use only; not needed for backtest) ---------
# The moomoo OpenAPI talks to a locally running OpenD gateway, not directly to
# the broker. These are placeholders for the future live/data adapter.
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_TRADE_PWD=
MOOMOO_ACCOUNT_ID=
