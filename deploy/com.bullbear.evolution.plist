<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.bullbear.evolution</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/yu-ga/Library/Application Support/BullBear/run-evolution-launchd.sh</string>
  </array>
  <!-- 07:00 JST is after the US close in both DST regimes (16:00 ET = 05:00/06:00
       JST), so the paper runner is sleeping and the shadow track records for the
       day are final. Runs once daily. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>/Users/yu-ga/Library/Logs/bullbear-evolution.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/yu-ga/Library/Logs/bullbear-evolution.stderr.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
  </dict>
</dict>
</plist>
